# Sentinel X Configuration

# Trading symbols (comma-separated)
SYMBOLS=AAPL,TSLA,BTC-USD,ETH-USD

# Timeframes in minutes (comma-separated)
TIMEFRAMES=15,60,240

# Risk limits
MAX_POSITION_SIZE=0.1
MAX_DAILY_LOSS=0.05

# Trading mode (PAPER or LIVE)
TRADE_MODE=PAPER

# Scheduler windows (hours 0-23)
TRAINING_WINDOW_START=0
TRAINING_WINDOW_END=6
TRADING_WINDOW_START=9
TRADING_WINDOW_END=16

# Engine settings
HEARTBEAT_INTERVAL=1.0
LOOP_SLEEP=0.1

# Paper trading capital
INITIAL_CAPITAL=100000.0

# Kill switch (set to true to stop immediately)
# KILL_SWITCH=false

# Alpaca Paper Trading (optional)
# If not configured, system will use simulated paper executor
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Position limits
MAX_POSITION_PER_SYMBOL=0.1
